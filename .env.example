# Voidlet environment variables.
# Copy this file to .env.local for local development (never commit .env.local).
# In production, set the same variables in Netlify → Site configuration →
# Environment variables.

# ── Phase 2: Supabase (auth + database) ─────────────────────────────
# Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# "Publishable" key (sb_publishable_...) or legacy anon key — public by design
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Phase 3: Stripe (payments) — not needed yet ─────────────────────
# "Secret" key (sb_secret_...) or legacy service_role key. Server-only:
# required from Phase 3 for webhook database writes. NEVER expose to the client.
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# Canonical site URL used in auth email redirects (e.g. https://voidlet.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
